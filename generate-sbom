#!/bin/bash

set -e

# Script behavior
SCAN_PATH="${1:-.}"
OUTPUT_FILE="${2:-sbom.json}"

echo "🔍 Starting SBOM generation..."
echo "  Scan Path: $SCAN_PATH"
echo "  Output File: $OUTPUT_FILE"

# Call the SBOM generator script
/opt/sbom/scripts/sbom-generator.sh "$SCAN_PATH" "$OUTPUT_FILE"

if [ ! -f "$OUTPUT_FILE" ]; then
    echo "❌ Failed to generate SBOM"
    exit 1
fi

echo "✅ SBOM generated successfully"
echo "📄 Output: $OUTPUT_FILE"

# Set output variable for GitHub Actions
if [ -n "${GITHUB_OUTPUT:-}" ]; then
    echo "sbom-file=$OUTPUT_FILE" >> "$GITHUB_OUTPUT"
fi

# Optionally upload the SBOM to an API endpoint via HTTP POST.
# Enabled only when API_URL is a non-empty value (mapped from the api-url
# input); API_KEY (from the api-key input) is sent as the X-Api-Key header when
# present. Surrounding whitespace is trimmed so a blank api-url disables upload.
API_URL="${API_URL:-}"
API_URL="${API_URL#"${API_URL%%[![:space:]]*}"}"   # strip leading whitespace
API_URL="${API_URL%"${API_URL##*[![:space:]]}"}"   # strip trailing whitespace

if [ -z "$API_URL" ]; then
    echo "ℹ️  api-url is empty; skipping API upload."
else
    echo "📡 Uploading SBOM to $API_URL ..."

    auth_args=()
    if [ -n "${API_KEY:-}" ]; then
        auth_args=(-H "X-Api-Key: ${API_KEY}")
    fi

    response_body="$(mktemp)"
    http_code="$(curl -sS -X POST \
        -H "Content-Type: application/json" \
        "${auth_args[@]}" \
        --data-binary "@${OUTPUT_FILE}" \
        -o "$response_body" \
        -w '%{http_code}' \
        "$API_URL")" || {
            echo "❌ SBOM upload failed (could not reach $API_URL)"
            rm -f "$response_body"
            exit 1
        }

    if [ "$http_code" -ge 200 ] && [ "$http_code" -lt 300 ]; then
        echo "✅ SBOM uploaded successfully (HTTP $http_code)"
    else
        echo "❌ SBOM upload failed (HTTP $http_code)"
        cat "$response_body"
        rm -f "$response_body"
        exit 1
    fi
    rm -f "$response_body"
fi
