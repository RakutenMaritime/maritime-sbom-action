#!/bin/bash

set -e

# Script behavior
SCAN_PATH="${1:-.}"
OUTPUT_FILE="${2:-sbom.json}"

echo "🔍 Starting SBOM generation..."
echo "  Scan Path: $SCAN_PATH"
echo "  Output File: $OUTPUT_FILE"

# Call the SBOM generator script
/opt/sbom/scripts/sbom-generator.sh "$SCAN_PATH" "$OUTPUT_FILE"

if [ ! -f "$OUTPUT_FILE" ]; then
    echo "❌ Failed to generate SBOM"
    exit 1
fi

echo "✅ SBOM generated successfully"
echo "📄 Output: $OUTPUT_FILE"

# Set output variable for GitHub Actions
if [ -n "${GITHUB_OUTPUT:-}" ]; then
    echo "sbom-file=$OUTPUT_FILE" >> "$GITHUB_OUTPUT"
fi
