#!/bin/bash

set -e

# Script behavior
SCAN_PATH="${1:-.}"
OUTPUT_FILE="${2:-sbom.json}"

echo "🔍 Starting SBOM generation..."
echo "  Scan Path: $SCAN_PATH"
echo "  Output File: $OUTPUT_FILE"

# Call the SBOM generator script
/opt/sbom/scripts/sbom-generator.sh "$SCAN_PATH" "$OUTPUT_FILE"

if [ ! -f "$OUTPUT_FILE" ]; then
    echo "❌ Failed to generate SBOM"
    exit 1
fi

echo "✅ SBOM generated successfully"
echo "📄 Output: $OUTPUT_FILE"

# Set output variable for GitHub Actions
if [ -n "${GITHUB_OUTPUT:-}" ]; then
    echo "sbom-file=$OUTPUT_FILE" >> "$GITHUB_OUTPUT"
fi

# Display the generated SBOM: a component count + table to the logs, and the
# same table to the GitHub job summary when running in Actions.
component_count="$(jq -r '.componentCount // (.components | length)' "$OUTPUT_FILE")"
echo "📊 SBOM contains ${component_count} component(s):"
jq -r '.components[]? | "  - \(.name)@\(.version) (\(.purl))"' "$OUTPUT_FILE"

if [ -n "${GITHUB_STEP_SUMMARY:-}" ]; then
    repo="$(jq -r '.metadata.repository // "-"' "$OUTPUT_FILE")"
    commit="$(jq -r '.metadata.commit // "-"' "$OUTPUT_FILE")"
    branch="$(jq -r '.metadata.branch // "-"' "$OUTPUT_FILE")"
    {
        echo "### 📦 SBOM (\`${OUTPUT_FILE}\`)"
        echo
        echo "- **Repository:** ${repo}"
        echo "- **Branch:** ${branch}"
        echo "- **Commit:** ${commit}"
        echo "- **Components:** ${component_count}"
        echo
        echo "| Name | Version | Type | purl |"
        echo "|------|---------|------|------|"
        jq -r '.components[]? | "| \(.name) | \(.version) | \(.type // "") | `\(.purl)` |"' "$OUTPUT_FILE"
    } >> "$GITHUB_STEP_SUMMARY"
fi
